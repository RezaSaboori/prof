# .env  — NEVER commit this file
DJANGO_SECRET_KEY="your-very-long-random-django-secret-key"
DEBUG=True

# Google OAuth  (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID="your-google-oauth-client-id-here"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret-here"

# Supabase
SUPABASE_URL="https://tfuwjbjugjtqrjsjwslq.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key-here"

# n8n Gateway Webhook
N8N_GATEWAY_URL="https://your-n8n-instance.example.com/webhook/gateway"
N8N_GATEWAY_SECRET_HEADER_NAME="X-Workflow-Secret"
N8N_GATEWAY_SECRET_HEADER_VALUE="your-webhook-secret-here"